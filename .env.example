APP_NAME=SahkarAI
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8002

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
BCRYPT_ROUNDS=12

# container-native: structured logs straight to stderr
LOG_CHANNEL=stderr
LOG_STACK=stderr
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=pgsql
DB_HOST=postgres
DB_PORT=5432
DB_DATABASE=app
DB_USERNAME=app
DB_PASSWORD=secret

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=reverb
FILESYSTEM_DISK=local
QUEUE_CONNECTION=redis

CACHE_STORE=redis

REDIS_CLIENT=phpredis
REDIS_HOST=redis
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log

# Laravel AI SDK. Set one provider key when a product adds its first agent.
AI_DEFAULT_PROVIDER=openai
AI_DEFAULT_MODEL=gpt-5-mini
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# --- Reverb (WebSockets) ---
# server-side: how the app publishes to the Reverb server
REVERB_APP_ID=conformance
REVERB_APP_KEY=conformancekey
REVERB_APP_SECRET=conformancesecret
REVERB_HOST=reverb
REVERB_PORT=8080
REVERB_SCHEME=http

# reverb server bind
REVERB_SERVER_HOST=0.0.0.0
REVERB_SERVER_PORT=8080

# browser-side
VITE_APP_NAME="${APP_NAME}"
VITE_REVERB_APP_KEY="${REVERB_APP_KEY}"
VITE_REVERB_HOST=localhost
VITE_REVERB_PORT=8082
VITE_REVERB_SCHEME=http
