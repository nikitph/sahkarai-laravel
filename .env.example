APP_NAME=SahkarAI
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8002

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
BCRYPT_ROUNDS=12

# Temporary convenience for deployments without outbound email. Leave false to
# retain the product spec's unverified-at-signup behavior.
AUTO_VERIFY_EMAIL=false

# container-native: structured logs straight to stderr
LOG_CHANNEL=stderr
LOG_STACK=stderr
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=pgsql
DB_HOST=postgres
DB_PORT=5432
DB_DATABASE=app
DB_USERNAME=app
DB_PASSWORD=secret

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=reverb
FILESYSTEM_DISK=local
QUEUE_CONNECTION=redis

CACHE_STORE=redis

REDIS_CLIENT=phpredis
REDIS_HOST=redis
REDIS_PASSWORD=null
REDIS_PORT=6379
REDIS_QUEUE_RETRY_AFTER=240
REDIS_QUEUE_AFTER_COMMIT=true

MAIL_MAILER=log

# Laravel AI SDK + DeepSeek. The application boots without a key; interpretation
# generation and chat prompts require one.
AI_DEFAULT_PROVIDER=deepseek
AI_DEFAULT_MODEL=deepseek-chat
DEEPSEEK_API_KEY=
SAHKAR_AI_PROVIDER=deepseek
SAHKAR_INTERPRETATION_MODEL=deepseek-chat
SAHKAR_CHAT_MODEL=deepseek-chat
SAHKAR_PROMPT_VERSION=2026-07-16.2
SAHKAR_INTERPRETATION_ATTEMPTS=3
CONTEXT_WINDOW_TOKEN_THRESHOLD=16000

# Regulatory acquisition. Configure RSS/Atom endpoints independently; a missing
# endpoint produces an auditable failed poll instead of silently doing nothing.
REGULATORY_STORAGE_DISK=local
REGULATORY_BACKFILL_MONTHS=12
REGULATORY_MAX_DOCUMENT_BYTES=52428800
RBI_FEED_URL=
INCOME_TAX_FEED_URL=
GST_FEED_URL=

# Razorpay. Prices stay in config/sahkarai.php; plan IDs identify the provider plans.
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=
RAZORPAY_TIER_1_PLAN_ID=
RAZORPAY_TIER_2_PLAN_ID=
RAZORPAY_TIER_3_PLAN_ID=
RAZORPAY_BASE_URL=https://api.razorpay.com/v1

# Dormant v1 seam. Leave empty to hide the credit top-up CTA.
CREDIT_TOPUP_URL=

# --- Reverb (WebSockets) ---
# server-side: how the app publishes to the Reverb server
REVERB_APP_ID=conformance
REVERB_APP_KEY=conformancekey
REVERB_APP_SECRET=conformancesecret
REVERB_HOST=reverb
REVERB_PORT=8080
REVERB_SCHEME=http

# reverb server bind
REVERB_SERVER_HOST=0.0.0.0
REVERB_SERVER_PORT=8080

# browser-side, shared by Inertia at request time (not baked into Vite assets)
REVERB_PUBLIC_APP_KEY="${REVERB_APP_KEY}"
REVERB_PUBLIC_HOST=localhost
REVERB_PUBLIC_PORT=8082
REVERB_PUBLIC_SCHEME=http

VITE_APP_NAME="${APP_NAME}"
